rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitive Helpers
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    
    // Validation for User
    function isValidUser(data) {
      return data.keys().hasAll(['fullName', 'email', 'createdAt']) &&
             data.fullName is string && data.fullName.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.createdAt is string && data.createdAt.size() <= 100 &&
             (!('phone' in data) || (data.phone is string && data.phone.size() <= 50)) &&
             (!('businessName' in data) || (data.businessName is string && data.businessName.size() <= 100)) &&
             (!('website' in data) || (data.website is string && data.website.size() <= 200)) &&
             (!('industry' in data) || (data.industry is string && data.industry.size() <= 100));
    }

    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      
      allow create: if isSignedIn() &&
                    request.auth.uid == userId &&
                    isValidId(userId) &&
                    isValidUser(incoming());

      allow update: if isSignedIn() &&
                    request.auth.uid == userId &&
                    isValidUser(incoming()) &&
                    // Temporal Integrity Check
                    incoming().createdAt == existing().createdAt &&
                    incoming().diff(existing()).affectedKeys().hasOnly([
                      'fullName', 'phone', 'businessName', 'website', 'industry'
                    ]);
    }

    // Validation for Survey
    function isValidSurvey(data) {
      return data.keys().hasAll(['fullName', 'email', 'score', 'createdAt']) &&
             data.fullName is string && data.fullName.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.score is number &&
             data.createdAt is string && data.createdAt.size() <= 100 &&
             (!('userId' in data) || (data.userId is string && data.userId.size() <= 128)) &&
             (!('phone' in data) || (data.phone is string && data.phone.size() <= 50)) &&
             (!('businessName' in data) || (data.businessName is string && data.businessName.size() <= 100)) &&
             (!('website' in data) || (data.website is string && data.website.size() <= 200)) &&
             (!('interest' in data) || (data.interest is string && data.interest.size() <= 100)) &&
             (!('answers' in data) || (data.answers is string && data.answers.size() <= 20000));
    }

    match /surveys/{surveyId} {
      // Anyone can create a survey (no auth required generally, but we can allow it)
      allow create: if isValidId(surveyId) &&
                    isValidSurvey(incoming());
    }
  }
}
